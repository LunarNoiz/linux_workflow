#!/bin/bash
# oc-init: Initializes a project with the Opencode/Claude Harness framework.

set -e

# --- Help Section ---
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Usage: oc-init [template_name]"
    echo ""
    echo "Initializes the current directory with the AI Multi-Agent Harness framework."
    echo "This creates .claude/ and .opencode/ directories and copies the appropriate"
    echo "templates into them, ensuring clean project roots."
    echo ""
    echo "Available templates:"
    echo "  python  - Enforces ruff linting and pytest"
    echo "  web     - Enforces package.json, eslint, and npm test"
    echo "  c_cpp   - Enforces make/cmake and clang-tidy"
    echo "  go      - Enforces go fmt, vet, staticcheck, and go test"
    echo "  generic - A blank slate. Use this for unknown languages/frameworks."
    echo ""
    echo "Example:"
    echo "  oc-init web"
    exit 0
fi

# Use the script's location to find the harness directory relative to the project root
# Since this script is in bin/, we can go up one level to find opencode-harness
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
HARNESS_DIR="$PROJECT_ROOT/opencode-harness/templates"

HOOK_TEMPLATE="#!/bin/bash

# Opencode Pre-push Hook (Garbage Collection)
# This triggers the garbage collector before code is pushed to remote.

echo \"Running Opencode Garbage Collection...\"
oc-gc || {
  echo \"Garbage collection failed or found issues that need manual review.\"
  echo \"Push aborted. You can bypass this with git push --no-verify\"
  exit 1
}

exit 0
"

if [ $# -eq 0 ]; then
    echo "No template specified. Please select a template to initialize:"
    # Dynamically read available templates from the directory
    mapfile -t templates < <(ls -1 "$HARNESS_DIR")
    templates+=("quit")
    
    PS3="Selection: "
    select choice in "${templates[@]}"; do
        if [ "$choice" = "quit" ]; then
            echo "Initialization aborted."
            exit 0
        elif [ -n "$choice" ]; then
            TEMPLATE="$choice"
            break
        else
            echo "Invalid selection."
            # Force exit on EOF or bad input to prevent infinite loop or failing with empty template
            if [[ -z "$REPLY" ]] || [[ "$REPLY" == "quit" ]]; then
                exit 1
            fi
        fi
    done

    if [ -z "$TEMPLATE" ]; then
        echo "No valid template selected. Aborting."
        exit 1
    fi
elif [ $# -eq 1 ]; then
    TEMPLATE=$1
else
    echo "Usage: oc-init [template_name]"
    echo "Run 'oc-init --help' for more information."
    exit 1
fi

if [ ! -d "$HARNESS_DIR/$TEMPLATE" ]; then
    echo "Error: Template '$TEMPLATE' not found in $HARNESS_DIR"
    exit 1
fi

echo "Initializing AI harness using template '$TEMPLATE'..."

# Check if directories already exist to prevent overwrite
if [ -d ".claude" ] || [ -d ".opencode" ]; then
    echo "Warning: .claude/ or .opencode/ already exists in this directory."
    echo "Initialization aborted to prevent overwriting existing configurations."
    exit 1
fi

# 1. Create the directories
mkdir -p .claude
mkdir -p .opencode/agents
mkdir -p .opencode/commands
mkdir -p .opencode/prompts

# 2. Copy the contents of the .claude/ folder from the template
cp -r "$HARNESS_DIR/$TEMPLATE/.claude/." .claude/

# 3. Copy the contents of the .opencode/ folder from the template
cp -r "$HARNESS_DIR/$TEMPLATE/.opencode/." .opencode/

# 4. Ensure run-checks.sh is executable
if [ -f ".claude/run-checks.sh" ]; then
    chmod +x .claude/run-checks.sh
fi

# 5. Setup git hook if it's a git repo
if [ -d ".git" ]; then
    HOOK_DIR=".git/hooks"
    PRE_PUSH="$HOOK_DIR/pre-push"
    
    echo "$HOOK_TEMPLATE" > "$PRE_PUSH"
    chmod +x "$PRE_PUSH"
    echo "Installed git pre-push hook for automatic garbage collection."
else
    echo "Not a git repository. Skipping pre-push hook installation."
fi

echo "Initialization complete!"
echo ".claude/ and .opencode/ have been populated from the '$TEMPLATE' template."

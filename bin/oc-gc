#!/bin/bash
# oc-gc: Manual garbage collection script.

# --- Help Section ---
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    echo "Usage: oc-gc"
    echo ""
    echo "Triggers a manual Garbage Collection pass using the 'code-gc' agent."
    echo "This is automatically run by the pre-push hook (if installed via oc-init),"
    echo "but can be run manually at any time."
    echo ""
    echo "The agent will:"
    echo "  1. Read .claude/OPENCODE.md rules."
    echo "  2. Scan the project for dead code, unused imports, and commented-out blocks."
    echo "  3. Remove the garbage."
    echo "  4. Ensure .claude/run-checks.sh still passes."
    echo "  5. Commit the cleanups automatically."
    exit 0
fi

PROMPT="Please use the Task tool to launch the 'code-gc' subagent to perform the following Garbage Collection pass:
1. Read .claude/OPENCODE.md to understand the current rules.
2. Scan the current project directory for any files that violate the rules in .claude/OPENCODE.md.
3. Specifically look for and remove unused code, commented-out dead code, or obsolete configuration.
4. Run '.claude/run-checks.sh' to ensure your cleanup did not break anything.
5. If changes were made and tests pass, commit the changes with a message like 'chore: AI garbage collection cleanup'. If no changes were needed, just report that the codebase is clean."

echo "Triggering AI Garbage Collection..."
opencode run "$PROMPT"

#!/bin/bash
# oc-do: Runs an Opencode task wrapped in the Supervisor loop.

if [ -z "$1" ]; then
    echo "Usage: oc-do \"<your task description>\""
    exit 1
fi

TASK="$1"

# The prompt forces the strict Feedback Loop.
PROMPT="TASK: $TASK

CRITICAL SUPERVISOR WORKFLOW (STRICT ENFORCEMENT):
1. READ FIRST: You MUST read OPENCODE.md and execute './run-checks.sh' to establish a baseline before writing ANY code. If baseline checks fail, fix the environment/dependencies immediately.
2. TDD ENFORCEMENT: If fixing a bug or adding a feature, you MUST write a test that fails first, then write the code to make it pass.
3. EXECUTE: Complete the requested task.
4. GATEKEEPER: Before concluding, you MUST launch the 'error-checker' subagent via the Task tool. Instruct it to run './run-checks.sh'.
5. FIX LOOP: If the gatekeeper fails, you MUST fix the code, write a new test to cover the edge case, and invoke the gatekeeper again.
6. KNOWLEDGE CAPTURE: If an error occurred that wasn't covered in OPENCODE.md, you MUST append a new constraint to OPENCODE.md.
7. NEVER exit successfully if './run-checks.sh' fails or is bypassed."

echo "Starting Opencode in Supervisor Loop..."
opencode run "$PROMPT"
